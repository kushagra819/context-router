# Copy to .env and fill in your keys.  .env is gitignored.
# Multiple keys per provider are supported for rotation: add _2, _3, ... up to _15
# (see src/utils/config.py). Tier 1 (Ollama) is local and needs no key.

# --- Tier 2: Groq (free) ---  Llama-3.3-70B.  https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here
# GROQ_API_KEY_2=
# GROQ_API_KEY_3=

# --- Tier 3: Llama-4-Maverick (free) ---  (replaces the sunset Llama-3.1-405B)
# PRIMARY  = Groq (reuses GROQ_API_KEY above; a SEPARATE per-model rate limit from
#            Tier 2, so one Groq key serves both Llama-70B and Llama-4-Maverick).
# FALLBACK = OpenRouter free Maverick (separate key pool so the strong tier never
#            goes dark mid-run).  https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
# OPENROUTER_API_KEY_2=

# --- Tier 4: GPT-4.1 frontier (own key pool; decoupled from Tier 3 -> fixes R1) ---
# PREFERRED = a DIRECT OpenAI key (stable, reproducible).  https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here
# OPENAI_API_KEY_2=
# FALLBACK = GitHub Models (free GPT-4.1). Fine-grained PAT, "Models" read access.
# https://github.com/settings/tokens
GITHUB_TOKEN=your_github_pat_here
# GITHUB_TOKEN_2=

# --- Optional alternative Tier-3 backends (src/models/alt_providers/) ---
# SAMBANOVA_API_KEY=your_sambanova_key      # DeepSeek-V3.1 (alt strong tier)
# GOOGLE_API_KEY=your_google_ai_studio_key  # GeminiModel (needs google-generativeai)
